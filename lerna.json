{
  "packages": [
    "packages/apps/*",
    "packages/components",
    "packages/mediastream-api",
    "packages/system-devices",
    "packages/video-processor",
    "packages/timeout-requester",
    "packages/utils",
    "packages/audio-utils",
    "packages/noise-suppression",
    "packages/features",
    "packages/hooks",
    "packages/framework",
    "packages/mst-tools",
    "packages/test-utils"
  ],
  "npmClient": "yarn",
  "command": {
    "run": { "npmClient": "yarn" },
    "publish": { "conventionalCommits": true },
    "version": {
      "message": "chore(release): publish",
      "ignoreChanges": [
        "**/__mocs__/**",
        "**/__fixtures__/**",
        "**/__tests__/**",
        "**/__tests-utils__/**",
        "**/*.md",
        "package.json"
      ]
    }
  },
  "version": "3.1.0",
  "$schema": "node_modules/lerna/schemas/lerna-schema.json"
}
