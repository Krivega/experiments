{
  "name": "camera-test",
  "version": "0.0.0",
  "license": "UNLICENSED",
  "scripts": {
    "build": "vite build",
    "deps:check": "ncu",
    "deps:update": "ncu -u",
    "format": "prettier --write \"src/**/*.{js,ts,tsx,json}\"",
    "lint": "yarn lint:ts && yarn lint:js",
    "lint:js": "eslint src/. --ext .js,.jsx,.ts,.tsx --max-warnings 0 --cache --cache-strategy=content",
    "lint:ts": "tsc",
    "precommit": "lint-staged",
    "start": "vite",
    "test": "jest",
    "test:circular": "madge --circular src/index.tsx"
  },
  "jest": {
    "collectCoverageFrom": [
      "src/**/*.{js,jsx}",
      "!<rootDir>/node_modules/",
      "!src/*.{js,jsx}",
      "!src/containers/Root/*.{js,jsx}",
      "!src/store/*.{js,jsx}",
      "!**/__tests-utils__/**",
      "!**/__mocks__/**"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 0,
        "branches": 0,
        "functions": 0,
        "lines": 0
      }
    }
  },
  "dependencies": {
    "@experiments/components": "*",
    "@experiments/mediastream-api": "*",
    "@experiments/system-devices": "*",
    "@experiments/utils": "*",
    "@material-ui/core": "^4.12.4",
    "@material-ui/icons": "^4.11.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "prop-types": "^15.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "styled-components": "^6.3.12"
  },
  "devDependencies": {
    "lint-staged": "16.4.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vite-tsconfig-paths": "^6.1.1",
    "madge": "^8.0.0"
  }
}
