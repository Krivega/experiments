{
  "name": "noise-suppression",
  "version": "0.0.0",
  "license": "UNLICENSED",
  "scripts": {
    "build": "yarn init:deps && vite build",
    "deps:check": "ncu",
    "deps:update": "ncu -u",
    "format": "prettier --write \"src/**/*.{js,ts,tsx,json}\"",
    "init:deps": " lerna run build --scope @experiments/noise-suppression   && cp-cli ../../noise-suppression/dist/noiseSuppressorWorkletRnnoise.js public/@experiments/noise-suppression/noiseSuppressorWorkletRnnoise.js && cp-cli ../../noise-suppression/dist/noiseSuppressorWorkletDtln.js public/@experiments/noise-suppression/noiseSuppressorWorkletDtln.js",
    "lint": "yarn lint:ts && yarn lint:js",
    "lint:js": "eslint src/. --ext .js,.jsx,.ts,.tsx --max-warnings 0 --cache --cache-strategy=content",
    "lint:ts": "tsc",
    "start": "yarn init:deps && vite",
    "test": "jest --passWithNoTests",
    "test:ci": "cross-env CI=true jest --passWithNoTests",
    "test:coverage": "yarn test:ci --no-cache --coverage"
  },
  "dependencies": {
    "@experiments/audio-utils": "*",
    "@experiments/noise-suppression": "*",
    "debug": "4.3.4"
  },
  "devDependencies": {
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "cp-cli": "^2.0.0",
    "lint-staged": "14.0.1",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
