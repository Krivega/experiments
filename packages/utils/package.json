{
  "name": "@experiments/utils",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./doMock": {
      "import": "./src/doMock.ts",
      "default": "./src/doMock.ts"
    },
    "./testUtils": {
      "import": "./src/testUtils.ts",
      "default": "./src/testUtils.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "deps:check": "ncu",
    "deps:update": "ncu -u",
    "format": "prettier --write \"src/**/*.{js,ts,tsx,json}\"",
    "lint": "yarn lint:ts && yarn lint:js",
    "lint:js": "eslint src/. --ext .js,.jsx,.ts,.tsx --max-warnings 0 --cache --cache-strategy=content",
    "lint:ts": "tsc",
    "precommit": "lint-staged",
    "test": "react-scripts test --verbose=false --passWithNoTests"
  },
  "jest": {
    "collectCoverageFrom": [
      "src/**/*.{js,jsx}",
      "src/**/*.{js,jsx}",
      "!<rootDir>/node_modules/",
      "!**/__tests-utils__/**",
      "!**/__mocks__/**",
      "!/dist"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 0,
        "branches": 0,
        "functions": 0,
        "lines": 0
      }
    }
  },
  "dependencies": {
    "@krivega/cancelable-promise": "^1.1.4",
    "copy-to-clipboard": "^3.3.3",
    "jest-canvas-mock": "^2.5.2",
    "jwt-decode": "^4.0.0",
    "webrtc-mock": "^1.2.1",
    "whatwg-fetch": "^3.6.20"
  },
  "devDependencies": {
    "jest-extended": "^7.0.0",
    "lint-staged": "16.4.0"
  }
}
