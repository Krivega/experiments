{
  "name": "@experiments/timeout-requester",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./doMock": {
      "import": "./src/doMock.ts",
      "default": "./src/doMock.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "deps:check": "ncu",
    "deps:update": "ncu -u",
    "format": "prettier --write \"src/**/*.{js,ts,tsx,json}\"",
    "lint": "yarn lint:ts && yarn lint:js",
    "lint:js": "eslint src/. --ext .js,.jsx,.ts,.tsx --max-warnings 0 --cache --cache-strategy=content",
    "lint:ts": "tsc",
    "precommit": "lint-staged",
    "test": "jest --passWithNoTests",
    "test:ci": "cross-env CI=true jest --passWithNoTests",
    "test:coverage": "yarn test:ci --no-cache --coverage"
  },
  "dependencies": {
    "@krivega/cancelable-promise": "^1.1.4"
  },
  "devDependencies": {
    "jest-extended": "^7.0.0",
    "lint-staged": "16.4.0"
  }
}
