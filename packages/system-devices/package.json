{
  "name": "@experiments/system-devices",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./testUtils": {
      "import": "./src/testUtils.ts",
      "default": "./src/testUtils.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "deps:check": "ncu",
    "deps:update": "ncu -u",
    "format": "prettier --write \"src/**/*.{js,ts,tsx,json}\"",
    "lint": "yarn lint:ts && yarn lint:js",
    "lint:js": "eslint src/. --ext .js,.jsx,.ts,.tsx --max-warnings 0 --cache --cache-strategy=content",
    "lint:ts": "tsc",
    "precommit": "lint-staged",
    "test": "jest --passWithNoTests",
    "test:ci": "cross-env CI=true jest --passWithNoTests",
    "test:coverage": "yarn test:ci --no-cache --coverage"
  },
  "dependencies": {
    "@experiments/mediastream-api": "*",
    "@experiments/utils": "*",
    "debug": "^4.4.3",
    "@krivega/cancelable-promise": "^1.1.4",
    "webrtc-mock": "^1.2.1"
  },
  "devDependencies": {
    "lint-staged": "16.4.0",
    "@types/debug": "^4.1.13"
  }
}
