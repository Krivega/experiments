{
  "name": "@experiments/features",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "deps:check": "ncu",
    "deps:update": "ncu -u",
    "format": "prettier --write \"src/**/*.{js,ts,tsx,json}\"",
    "lint": "yarn lint:ts && yarn lint:js",
    "lint:js": "eslint src/. --ext .js,.jsx,.ts,.tsx --max-warnings 0 --cache --cache-strategy=content",
    "lint:ts": "tsc",
    "precommit": "lint-staged",
    "test": "jest --passWithNoTests",
    "test:ci": "cross-env CI=true jest --passWithNoTests",
    "test:coverage": "yarn test:ci --no-cache --coverage"
  },
  "dependencies": {
    "@experiments/components": "*",
    "@experiments/framework": "*",
    "@experiments/hooks": "*",
    "@experiments/mst-tools": "*",
    "@experiments/test-utils": "*",
    "@experiments/timeout-requester": "*",
    "@experiments/utils": "*",
    "@krivega/cancelable-promise": "^1.1.4",
    "debug": "^4.4.3",
    "linkify-react": "^4.3.2",
    "lodash": "^4.17.23",
    "mobx": "6.15.0",
    "mobx-react": "^9.2.1",
    "mobx-state-tree": "^7.1.0",
    "react": "^19.2.4",
    "react-intl": "^10.1.1",
    "xstate": "^5.30.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/debug": "^4.1.13",
    "eslint-plugin-formatjs": "^6.4.4",
    "jest-extended": "^7.0.0",
    "lint-staged": "16.4.0",
    "promise-delay": "^2.1.0"
  },
  "main:src": "src/index.ts"
}
