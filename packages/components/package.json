{
  "name": "@experiments/components",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "deps:check": "ncu",
    "deps:update": "ncu -u",
    "format": "prettier --write \"src/**/*.{js,ts,tsx,json}\"",
    "lint": "yarn lint:js && yarn lint:ts",
    "lint:js": "eslint src/. --ext .js,.jsx,.ts,.tsx --max-warnings 0 --cache --cache-strategy=content",
    "lint:ts": "tsc",
    "precommit": "lint-staged",
    "test": "react-scripts test --verbose=false --passWithNoTests"
  },
  "jest": {
    "collectCoverageFrom": [
      "src/**/*.{js,jsx}",
      "src/**/*.{js,jsx}",
      "!<rootDir>/node_modules/",
      "!**/__tests-utils__/**",
      "!**/__mocks__/**",
      "!/dist"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 0,
        "branches": 0,
        "functions": 0,
        "lines": 0
      }
    }
  },
  "dependencies": {
    "@experiments/audio-utils": "*",
    "@experiments/utils": "*",
    "debug": "^4.4.3",
    "lodash": "^4.17.23",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/debug": "^4.1.13",
    "lint-staged": "16.4.0"
  },
  "main:src": "src/index.ts"
}
