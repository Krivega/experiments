{
  "name": "@experiments/mediastream-api",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "main": "src/index.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "deps:check": "ncu",
    "deps:update": "ncu -u",
    "format": "prettier --write \"src/**/*.{js,ts,tsx,json}\"",
    "lint": "yarn lint:js && yarn lint:ts",
    "lint:js": "eslint src/. --ext .js,.jsx,.ts,.tsx --max-warnings 0 --cache --cache-strategy=content",
    "lint:ts": "tsc",
    "precommit": "lint-staged",
    "test": "react-scripts test --verbose=false --passWithNoTests"
  },
  "jest": {
    "collectCoverageFrom": [
      "src/**/*.{js,jsx}",
      "src/**/*.{js,jsx}",
      "!<rootDir>/node_modules/",
      "!**/__tests-utils__/**",
      "!**/__mocks__/**",
      "!/dist"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 0,
        "branches": 0,
        "functions": 0,
        "lines": 0
      }
    }
  },
  "dependencies": {
    "@experiments/timeout-requester": "*",
    "@experiments/utils": "^0.0.0",
    "@krivega/cancelable-promise": "^1.1.4",
    "debug": "^4.4.3",
    "lodash": "^4.17.23",
    "repeated-calls": "^2.4.0",
    "sequent-promises": "^2.0.1",
    "webrtc-mock": "^1.2.1"
  },
  "devDependencies": {
    "@types/debug": "^4.1.13",
    "lint-staged": "16.4.0"
  },
  "main:src": "src/index.ts"
}
