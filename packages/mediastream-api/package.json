    "sequent-promises": "^2.0.1",
    "webrtc-mock": "^1.2.1"
  },
  "devDependencies": {
    "@types/debug": "^4.1.13",
    "lint-staged": "16.4.0"
  },
  "main:src": "src/index.ts"
