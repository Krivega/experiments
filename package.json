{
  "name": "root",
  "version": "0.0.0",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/apps/*",
      "packages/components",
      "packages/mediastream-api",
      "packages/system-devices",
      "packages/video-processor",
      "packages/timeout-requester",
      "packages/utils",
      "packages/audio-utils",
      "packages/noise-suppression"
    ],
    "nohoist": [
      "**/webpack-dev-server",
      "**/cross-env",
      "**/npm-run-all",
      "**/cp-cli",
      "**/rollup",
      "**/typescript",
      "**/typescript/**",
      "**/@types",
      "**/@types/**",
      "**/@tensorflow",
      "**/@tensorflow/**",
      "**/@tensorflow-models",
      "**/@tensorflow-models/**",
      "**/@mediapipe",
      "**/@mediapipe/**",
      "**/dtln-rs"
    ]
  },
  "scripts": {
    "deps:check": "ncu && lerna run deps:check --stream",
    "deps:update": "ncu -u && lerna run deps:update --stream && yarn",
    "lint": "lerna run lint --stream",
    "lint:js": "lerna run lint:js --stream",
    "lint:ts": "lerna run lint:ts --stream",
    "build:demo": "rimraf demoDist && mkdir -p demoDist && cross-env DEMO_APP_SEGMENT=camera-test yarn workspace camera-test build && cp -R packages/apps/camera-test/dist demoDist/camera-test && cross-env DEMO_APP_SEGMENT=noise-suppression yarn workspace noise-suppression build && cp -R packages/apps/noise-suppression/dist demoDist/noise-suppression && cp scripts/gh-pages-index.html demoDist/index.html && cp scripts/custom.css demoDist/custom.css",
    "precommit": "lerna run --concurrency 1 --stream precommit",
    "test": "CI=true yarn test:modules && CI=true yarn test:apps",
    "test:apps": "lerna run test:ci --parallel --scope camera-test --scope noise-suppression --scope video-processing",
    "test:modules": "lerna run test:ci --parallel --ignore camera-test --ignore noise-suppression --ignore video-processing",
    "tsc": "tsc"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-lerna-changelog"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/compat": "^2.0.3",
    "@krivega/eslint-config": "^1.1.19",
    "@lerna/filter-options": "^6.4.1",
    "@types/audioworklet": "0.0.97",
    "@types/dom-mediacapture-transform": "^0.1.11",
    "@types/filesystem": "^0.0.36",
    "@types/history": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.5.0",
    "@types/offscreencanvas": "2019.7.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/wicg-file-system-access": "^2023.10.7",
    "cross-env": "^10.1.0",
    "cz-lerna-changelog": "^2.0.3",
    "eslint": "9.39.2",
    "husky": "^9.1.7",
    "jest": "30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-extended": "^7.0.0",
    "jest-junit": "^16.0.0",
    "jiti": "2.6.1",
    "lerna": "^9.0.7",
    "postcss": "8.5.8",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.6",
    "typescript": "6.0.2"
  }
}
